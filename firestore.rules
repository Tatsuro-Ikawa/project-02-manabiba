rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ヘルパー関数: 認証済みユーザーのチェック
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ヘルパー関数: 自分のデータかチェック
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ヘルパー関数: ログイン中のユーザーが管理者（users/{uid}.role == 'admin'）か
    // users ドキュメントが存在しない、または role が 'admin' でない場合は false
    function isAdminUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data != null && userDoc.data.get('role', '') == 'admin';
    }

    // A-11: コーチ↔クライアント割当（ドキュメント ID = coachUid_clientUid）
    function coachClientAssignmentDocPath(coachUid, clientUid) {
      return /databases/$(database)/documents/coach_client_assignments/$(coachUid + '_' + clientUid);
    }

    function hasActiveCoachAssignmentForClient(clientUid) {
      let p = coachClientAssignmentDocPath(request.auth.uid, clientUid);
      return isAuthenticated() &&
        exists(p) &&
        get(p).data.status == 'active' &&
        get(p).data.coachUid == request.auth.uid &&
        get(p).data.clientUid == clientUid;
    }

    // 人コーチ（月次）を許可するか（サブスク由来のフラグで運用）。
    // 現状の型: users/{uid}.subscription.features.coachComments（boolean）
    function clientAllowsHumanCoachComments(clientUid) {
      let u = get(/databases/$(database)/documents/users/$(clientUid));
      let sub = u.data != null ? u.data.get('subscription', null) : null;
      let features = sub != null ? sub.get('features', null) : null;
      return features != null && features.get('coachComments', false) == true;
    }

    // 親の sharedWithCoach（子 read 判定のフォールバック）。存在・型ずれで落ちないよう get を使う。
    function affirmationSharedWithCoach(userId, affirmationId) {
      let p = /databases/$(database)/documents/users/$(userId)/affirmations/$(affirmationId);
      return exists(p) && get(p).data.get('sharedWithCoach', false) == true;
    }

    // 親の sharedWithCoach（journal_monthly の子 read 判定用）
    function journalMonthlySharedWithCoach(userId, monthKey) {
      let p = /databases/$(database)/documents/users/$(userId)/journal_monthly/$(monthKey);
      return exists(p) && get(p).data.get('sharedWithCoach', false) == true;
    }

    match /coach_client_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        resource.data.coachUid == request.auth.uid ||
        resource.data.clientUid == request.auth.uid ||
        isAdminUser()
      );
      allow create: if isAdminUser() &&
        assignmentId == request.resource.data.coachUid + '_' + request.resource.data.clientUid &&
        request.resource.data.keys().hasAll(['coachUid', 'clientUid', 'status', 'assignedAt']) &&
        request.resource.data.coachUid is string &&
        request.resource.data.clientUid is string &&
        request.resource.data.status is string;
      allow update, delete: if isAdminUser();
    }
    
    // ユーザープロファイル
    match /users/{userId} {
      // 読み取り: 本人、または担当コーチ（割当 active）
      allow read: if isOwner(userId) || hasActiveCoachAssignmentForClient(userId);
      
      // 作成: 自分のプロファイルのみ
      allow create: if isOwner(userId);
      
      // 更新: 自分のプロファイルのみ
      allow update: if isOwner(userId);
      
      // 削除: 自分のプロファイルのみ
      allow delete: if isOwner(userId);
      
      // SMART目標（サブコレクション）
      match /smart-goals/{goalId} {
        // 読み取り: 自分の目標のみ
        allow read: if isOwner(userId);
        
        // 作成: 自分の目標のみ
        allow create: if isOwner(userId) && 
          request.resource.data.uid == userId;
        
        // 更新: 自分の目標のみ
        allow update: if isOwner(userId) && 
          resource.data.uid == userId;
        
        // 削除: 自分の目標のみ
        allow delete: if isOwner(userId) && 
          resource.data.uid == userId;
      }

      // アファメーション（穴埋め）下書き
      match /affirmation_drafts/{profileId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // マネジメント日誌（学び帳）— 日次: 朝・晩
      // パス: users/{uid}/journal_daily/{dateKey}
      // 現段階: 本人のみ read/write（コーチ共有は A-11 等で後続）
      match /journal_daily/{dateKey} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // マネジメント日誌（学び帳）— 週次（SCREEN-006 実装時に利用）
      // パス: users/{uid}/journal_weekly/{weekStartKey}（JST・ユーザの週開始日基準の YYYY-MM-DD）
      match /journal_weekly/{weekStartKey} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // マネジメント日誌（学び帳）— 月次（月報）
      // パス: users/{uid}/journal_monthly/{monthKey}（JST・暦月の YYYY-MM）
      // コーチ read/write は A-11 同型（配下の rounds / comment_versions）で制御する
      match /journal_monthly/{monthKey} {
        // 本体: 本人 read/write。担当コーチは「active 割当」＋「共有 ON」＋「コーチコメント機能 ON」で read のみ。
        allow read: if isOwner(userId) || (
          hasActiveCoachAssignmentForClient(userId) &&
          resource.data.get('sharedWithCoach', false) == true &&
          clientAllowsHumanCoachComments(userId)
        );
        allow create, update, delete: if isOwner(userId);

        // クライアント送信（質問）ラウンド
        match /coach_share_rounds/{roundId} {
          allow read: if isOwner(userId) || (
            hasActiveCoachAssignmentForClient(userId) &&
            journalMonthlySharedWithCoach(userId, monthKey) &&
            clientAllowsHumanCoachComments(userId)
          );
          allow create: if isOwner(userId);
          allow update, delete: if false;

          // コーチコメント（版の追記のみ）
          match /coach_comment_versions/{versionId} {
            allow read: if isOwner(userId) || (
              hasActiveCoachAssignmentForClient(userId) &&
              journalMonthlySharedWithCoach(userId, monthKey) &&
              clientAllowsHumanCoachComments(userId)
            );
            allow create: if hasActiveCoachAssignmentForClient(userId) &&
              journalMonthlySharedWithCoach(userId, monthKey) &&
              clientAllowsHumanCoachComments(userId) &&
              request.resource.data.authorCoachUid == request.auth.uid &&
              request.resource.data.keys().hasAll(['encryptedBody', 'authorCoachUid', 'savedAt']);
            allow update, delete: if false;
          }
        }
      }

      // アファメーション文書（親＝メタ、案 B）— A-11 コーチ共有
      match /affirmations/{affirmationId} {
        allow read: if isOwner(userId) || (
          hasActiveCoachAssignmentForClient(userId) &&
          resource.data.get('sharedWithCoach', false) == true
        );
        allow create, delete: if isOwner(userId);
        allow update: if isOwner(userId) || (
          hasActiveCoachAssignmentForClient(userId) &&
          resource.data.get('sharedWithCoach', false) == true &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['clientUnreadLatestCoachReply', 'coachUnreadAfterClientShare', 'updatedAt'])
        );

        // published 本文: コーチ read は親 get に依存すると一覧と評価がずれることがあるため、
        // coachCanReadPublished を published/current に同期し resource で先に判定する。
        match /published/{docId} {
          allow read: if isOwner(userId) || (
            hasActiveCoachAssignmentForClient(userId) &&
            (
              resource.data.get('coachCanReadPublished', false) == true ||
              affirmationSharedWithCoach(userId, affirmationId)
            )
          );
          allow create, update, delete: if isOwner(userId);
        }

        match /history/{historyId} {
          allow read, create, update, delete: if isOwner(userId);
        }

        match /coach_share_rounds/{roundId} {
          allow read: if isOwner(userId) || (
            hasActiveCoachAssignmentForClient(userId) &&
            affirmationSharedWithCoach(userId, affirmationId)
          );
          allow create: if isOwner(userId);
          allow update, delete: if false;

          match /coach_comment_versions/{versionId} {
            allow read: if isOwner(userId) || (
              hasActiveCoachAssignmentForClient(userId) &&
              affirmationSharedWithCoach(userId, affirmationId)
            );
            allow create: if hasActiveCoachAssignmentForClient(userId) &&
              affirmationSharedWithCoach(userId, affirmationId) &&
              request.resource.data.authorCoachUid == request.auth.uid &&
              request.resource.data.keys().hasAll(['encryptedBody', 'authorCoachUid', 'savedAt']);
            allow update, delete: if false;
          }
        }
      }
    }
    
    // PDCAエントリ
    match /pdca_entries/{entryId} {
      // 読み取り: 自分のエントリのみ
      allow read: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
      
      // 作成: 自分のエントリのみ
      allow create: if isAuthenticated() && 
        request.resource.data.uid == request.auth.uid;
      
      // 更新: 自分のエントリのみ
      allow update: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
      
      // 削除: 自分のエントリのみ
      allow delete: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
    }
    
    // PDCA集約データ
    match /pdca_aggregations/{aggregationId} {
      // 読み取り: 自分の集約データのみ
      allow read: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
      
      // 作成: 自分の集約データのみ
      allow create: if isAuthenticated() && 
        request.resource.data.uid == request.auth.uid;
      
      // 更新: 自分の集約データのみ
      allow update: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
      
      // 削除: 自分の集約データのみ
      allow delete: if isAuthenticated() && 
        resource.data.uid == request.auth.uid;
    }
    
    // コーチングセッション
    match /coaching_sessions/{sessionId} {
      // 読み取り: 自分のセッションのみ
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // 作成: 自分のセッションのみ
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // 更新: 自分のセッションのみ
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // 削除: 自分のセッションのみ
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // 目標（goalsコレクション）
    match /goals/{goalId} {
      // 読み取り: 自分の目標のみ
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // 作成: 自分の目標のみ
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // 更新: 自分の目標のみ
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // 削除: 自分の目標のみ
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // AI分析
    match /ai_analyses/{analysisId} {
      // 読み取り: 自分の分析のみ
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // 作成: 自分の分析のみ
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // 更新: 自分の分析のみ
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // 削除: 自分の分析のみ
      allow delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // コーチング設定
    match /coaching_settings/{userId} {
      // 読み取り: 自分の設定のみ
      allow read: if isOwner(userId);
      
      // 作成: 自分の設定のみ
      allow create: if isOwner(userId) && 
        request.resource.data.userId == userId;
      
      // 更新: 自分の設定のみ
      allow update: if isOwner(userId) && 
        resource.data.userId == userId;
      
      // 削除: 自分の設定のみ
      allow delete: if isOwner(userId);
    }
    
    // サイト共通コンテンツ（ホーム画面: 最新動画・参考リンク等）
    match /site_content/home {
      // 読み取り: 未認証含む全員
      allow read: if true;
      // 作成・更新: 管理者（users/{uid}.role == 'admin'）のみ
      // ※ users ドキュメントが存在し、role フィールドが 'admin' のユーザーのみ書き込み可
      allow create, update: if isAuthenticated() && 
        isAdminUser();
      allow delete: if false;
    }
  }
}

